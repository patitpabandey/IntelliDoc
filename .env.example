# ── Snowflake ────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=<your-account-identifier>   # e.g. xy12345.us-east-1
SNOWFLAKE_USER=<your-snowflake-user>
SNOWFLAKE_PASSWORD=<your-snowflake-password>  # or use key-pair / OAuth
SNOWFLAKE_ROLE=INTELLIDOC_ROLE
SNOWFLAKE_WAREHOUSE=INTELLIDOC_WH
SNOWFLAKE_DATABASE=INTELLIDOC_DB
SNOWFLAKE_SCHEMA=INTELLIDOC

# ── AWS ───────────────────────────────────────────────────────────────────────
# DO NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here.
# Lambda uses its execution role; local dev uses AWS_PROFILE or instance metadata.
AWS_REGION=us-east-1
AWS_PROFILE=intellidoc-dev          # local only — remove before deploying

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=intellidoc-documents-source
S3_INCOMING_PREFIX=incoming/
S3_METADATA_PREFIX=metadata/
S3_VALIDATED_PREFIX=validated/
S3_QUARANTINE_PREFIX=quarantine/

# ── DynamoDB ──────────────────────────────────────────────────────────────────
# Table uses custody_country (PK) + legal_entity_id (SK)
DYNAMODB_TABLE_NAME=CustodyCollectionRegistry

# ── SQS ───────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/intellidoc-validation

# ── SNS ───────────────────────────────────────────────────────────────────────
SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:<account-id>:intellidoc-alerts

# ── Snowflake Storage Integration (created by Snowflake admin) ───────────────
SNOWFLAKE_STORAGE_INTEGRATION=INTELLIDOC_S3_INTEGRATION
